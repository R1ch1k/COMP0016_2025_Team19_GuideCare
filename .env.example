# OpenAI API (required)
OPENAI_API_KEY=sk-proj-your-key-here
OPENAI_MODEL=gpt-4o

# LLM Mode: "api" for OpenAI API, "local" for local model
LLM_MODE=api

# Local model settings (only used when LLM_MODE=local)
LOCAL_MODEL_URL=http://host.docker.internal:8080/v1
LOCAL_MODEL_NAME=gpt-oss-20b

# Frontend login password
TEAM_PASSWORD=changeme123
